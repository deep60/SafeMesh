{
    "tables": [
        {
            "table": "refresh_tokens",
            "description": "JWT refresh tokens for session management",
            "columns": [
                {
                    "name": "id",
                    "type": "TEXT",
                    "primary_key": true,
                    "description": "UUID v4 primary key"
                },
                {
                    "name": "user_id",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "FK to users.id"
                },
                {
                    "name": "token_hash",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "SHA256 hash of the refresh token"
                },
                {
                    "name": "expires_at",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "ISO 8601 expiration timestamp"
                },
                {
                    "name": "created_at",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "ISO 8601 creation timestamp"
                }
            ],
            "indexes": [
                {
                    "name": "idx_refresh_tokens_hash",
                    "columns": [
                        "token_hash"
                    ],
                    "unique": true
                },
                {
                    "name": "idx_refresh_tokens_user",
                    "columns": [
                        "user_id"
                    ]
                }
            ]
        },
        {
            "table": "password_reset_tokens",
            "description": "Password reset tokens for forgot-password flow",
            "columns": [
                {
                    "name": "id",
                    "type": "TEXT",
                    "primary_key": true,
                    "description": "UUID v4 primary key"
                },
                {
                    "name": "user_id",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "FK to users.id"
                },
                {
                    "name": "token_hash",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "SHA256 hash of the reset token"
                },
                {
                    "name": "expires_at",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "ISO 8601 expiration timestamp"
                },
                {
                    "name": "used",
                    "type": "INTEGER",
                    "nullable": false,
                    "default": 0,
                    "description": "Whether token has been used (0/1)"
                },
                {
                    "name": "created_at",
                    "type": "TEXT",
                    "nullable": false,
                    "description": "ISO 8601 creation timestamp"
                }
            ],
            "indexes": [
                {
                    "name": "idx_reset_tokens_hash",
                    "columns": [
                        "token_hash"
                    ],
                    "unique": true
                },
                {
                    "name": "idx_reset_tokens_user",
                    "columns": [
                        "user_id"
                    ]
                }
            ]
        }
    ]
}