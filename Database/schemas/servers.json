{
    "table": "vpn_servers",
    "description": "VPN server instances available for connection",
    "columns": [
        {
            "name": "id",
            "type": "TEXT",
            "primary_key": true,
            "description": "UUID v4 primary key"
        },
        {
            "name": "name",
            "type": "TEXT",
            "nullable": false,
            "description": "Server display name"
        },
        {
            "name": "city",
            "type": "TEXT",
            "nullable": false,
            "description": "City location"
        },
        {
            "name": "country",
            "type": "TEXT",
            "nullable": false,
            "description": "Country name"
        },
        {
            "name": "country_code",
            "type": "TEXT",
            "nullable": false,
            "default": "'US'",
            "description": "ISO 3166-1 alpha-2 country code"
        },
        {
            "name": "region",
            "type": "TEXT",
            "nullable": false,
            "default": "'North America'",
            "description": "Geographic region"
        },
        {
            "name": "ip_address",
            "type": "TEXT",
            "nullable": false,
            "description": "Server IP address"
        },
        {
            "name": "port",
            "type": "INTEGER",
            "nullable": false,
            "default": 51820,
            "description": "WireGuard listening port"
        },
        {
            "name": "public_key",
            "type": "TEXT",
            "nullable": false,
            "description": "WireGuard public key"
        },
        {
            "name": "endpoint",
            "type": "TEXT",
            "nullable": false,
            "description": "Full endpoint (ip:port)"
        },
        {
            "name": "dns_servers",
            "type": "TEXT",
            "nullable": false,
            "default": "'1.1.1.1,1.0.0.1'",
            "description": "Comma-separated DNS servers"
        },
        {
            "name": "protocol",
            "type": "TEXT",
            "nullable": false,
            "default": "'WireGuard'",
            "description": "Primary protocol"
        },
        {
            "name": "protocols",
            "type": "TEXT",
            "nullable": false,
            "default": "'WireGuard'",
            "description": "Comma-separated supported protocols"
        },
        {
            "name": "latency",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Latency in ms"
        },
        {
            "name": "load_percentage",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Server load 0-100"
        },
        {
            "name": "max_connections",
            "type": "INTEGER",
            "nullable": false,
            "default": 1000,
            "description": "Max concurrent connections"
        },
        {
            "name": "current_connections",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Current active connections"
        },
        {
            "name": "is_active",
            "type": "INTEGER",
            "nullable": false,
            "default": 1,
            "description": "Whether server is active (0/1)"
        },
        {
            "name": "is_premium",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Premium-only server (0/1)"
        },
        {
            "name": "status",
            "type": "TEXT",
            "nullable": false,
            "default": "'online'",
            "description": "Server status: online, offline, maintenance"
        },
        {
            "name": "created_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 creation timestamp"
        },
        {
            "name": "updated_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 last update timestamp"
        }
    ],
    "indexes": [
        {
            "name": "idx_servers_country",
            "columns": [
                "country_code"
            ]
        },
        {
            "name": "idx_servers_status",
            "columns": [
                "status",
                "is_active"
            ]
        }
    ]
}