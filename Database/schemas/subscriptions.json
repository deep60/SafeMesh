{
    "table": "subscriptions",
    "description": "User subscription plans and billing",
    "columns": [
        {
            "name": "id",
            "type": "TEXT",
            "primary_key": true,
            "description": "UUID v4 primary key"
        },
        {
            "name": "user_id",
            "type": "TEXT",
            "nullable": false,
            "description": "FK to users.id"
        },
        {
            "name": "plan_type",
            "type": "TEXT",
            "nullable": false,
            "description": "Plan ID: plan_free, plan_monthly, plan_yearly"
        },
        {
            "name": "status",
            "type": "TEXT",
            "nullable": false,
            "default": "'active'",
            "description": "Status: active, past_due, canceled, expired, pending, trial"
        },
        {
            "name": "start_date",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 subscription start"
        },
        {
            "name": "end_date",
            "type": "TEXT",
            "nullable": true,
            "description": "ISO 8601 subscription end"
        },
        {
            "name": "auto_renew",
            "type": "INTEGER",
            "nullable": false,
            "default": 1,
            "description": "Auto-renewal enabled (0/1)"
        },
        {
            "name": "max_bandwidth",
            "type": "INTEGER",
            "nullable": false,
            "default": 10737418240,
            "description": "Max bandwidth in bytes (default 10GB)"
        },
        {
            "name": "max_connections",
            "type": "INTEGER",
            "nullable": false,
            "default": 1,
            "description": "Max simultaneous connections"
        },
        {
            "name": "features",
            "type": "TEXT",
            "nullable": false,
            "default": "''",
            "description": "Comma-separated feature list"
        },
        {
            "name": "is_active",
            "type": "INTEGER",
            "nullable": false,
            "default": 1,
            "description": "Subscription active status (0/1)"
        },
        {
            "name": "created_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 creation timestamp"
        },
        {
            "name": "updated_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 last update timestamp"
        }
    ],
    "indexes": [
        {
            "name": "idx_subscriptions_user",
            "columns": [
                "user_id"
            ]
        },
        {
            "name": "idx_subscriptions_status",
            "columns": [
                "status",
                "is_active"
            ]
        }
    ]
}