{
    "table": "users",
    "description": "User accounts for SafeMesh VPN",
    "columns": [
        {
            "name": "id",
            "type": "TEXT",
            "primary_key": true,
            "description": "UUID v4 primary key"
        },
        {
            "name": "username",
            "type": "TEXT",
            "unique": true,
            "nullable": false,
            "description": "Unique username, auto-derived from email"
        },
        {
            "name": "name",
            "type": "TEXT",
            "nullable": false,
            "default": "''",
            "description": "Display name"
        },
        {
            "name": "email",
            "type": "TEXT",
            "unique": true,
            "nullable": false,
            "description": "Email address for login"
        },
        {
            "name": "password_hash",
            "type": "TEXT",
            "nullable": false,
            "description": "Bcrypt-hashed password"
        },
        {
            "name": "avatar_url",
            "type": "TEXT",
            "nullable": true,
            "description": "Profile picture URL"
        },
        {
            "name": "is_email_verified",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Whether email is verified (0/1)"
        },
        {
            "name": "two_factor_enabled",
            "type": "INTEGER",
            "nullable": false,
            "default": 0,
            "description": "Whether 2FA is enabled (0/1)"
        },
        {
            "name": "created_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 creation timestamp"
        },
        {
            "name": "updated_at",
            "type": "TEXT",
            "nullable": false,
            "description": "ISO 8601 last update timestamp"
        },
        {
            "name": "is_active",
            "type": "INTEGER",
            "nullable": false,
            "default": 1,
            "description": "Account active status (0/1)"
        }
    ],
    "indexes": [
        {
            "name": "idx_users_email",
            "columns": [
                "email"
            ],
            "unique": true
        },
        {
            "name": "idx_users_username",
            "columns": [
                "username"
            ],
            "unique": true
        }
    ]
}